rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── TEAMS ──────────────────────────────────────────────────────────────
    // Herkes okuyabilir (keşfet ekranı için), sadece sahibi yazabilir
    match /teams/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── SWIPES ─────────────────────────────────────────────────────────────
    match /swipes/{userId}/records/{recordId} {
      // Kendi swipe kayıtlarını yaz
      allow write: if request.auth != null && request.auth.uid == userId;

      // Kendi kayıtlarını oku (örn. kendi geçmişine bak)
      allow read: if request.auth != null && request.auth.uid == userId;

      // KARŞILIKLI EŞLEŞMİ KONTROL: 
      // Biri sana beğeni gönderdi mi? → swipes/{o_kişi}/records/{senin_uid}
      // recordId == senin UID'in ise okumana izin ver
      allow read: if request.auth != null && recordId == request.auth.uid;
    }

    // ── MATCHES ────────────────────────────────────────────────────────────
    // Eşleşmenin katılımcılarından biri ise tüm işlemler serbest
    match /matches/{matchId} {
      allow read, write: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      // Yeni maç oluştururken (resource yok) kendi uid'in participants'ta olmalı
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;

      // Sohbet mesajları
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── TOURNAMENT REGISTRATIONS ────────────────────────────────────────────
    match /tournament_registrations/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null &&
        request.resource.data.uid == request.auth.uid;
    }

    // ── DISPUTES ────────────────────────────────────────────────────────────
    match /disputes/{docId} {
      allow read, write: if request.auth != null;
    }

  }
}
